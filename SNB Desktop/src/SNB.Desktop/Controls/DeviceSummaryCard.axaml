<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SNB.Desktop.Controls"
             xmlns:conv="clr-namespace:SNB.Desktop.Converters"
             x:Class="SNB.Desktop.Controls.DeviceSummaryCard"
             x:Name="Root"
             x:DataType="controls:DeviceSummaryCard">

    <Border Classes="Card" Padding="14">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <!-- Device image with placeholder fallback -->
            <Panel Grid.Column="0" Width="48" Height="64" VerticalAlignment="Center">
                <Border CornerRadius="8"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <PathIcon Width="24" Height="24"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0.45"
                              Foreground="{StaticResource TextMutedBrush}"
                              Data="{StaticResource IconSmartphone}" />
                </Border>
                <Image Stretch="Uniform"
                       Source="{Binding #Root.Device.ImagePath, Converter={x:Static conv:BitmapAssetValueConverter.Instance}}" />
            </Panel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="{Binding #Root.Device.Name}"
                           Classes="Subtitle"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />

                <Border Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="{StaticResource PillCornerRadius}"
                        Padding="8,3"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding #Root.Device.AndroidVersionLabel}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <StackPanel Spacing="2">
                    <TextBlock Text="Serial Number" 
                               Classes="Caption" 
                               FontSize="11" />
                    <TextBlock Text="{Binding #Root.Device.Serial}" 
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Border Background="{StaticResource SuccessSoftBrush}"
                        CornerRadius="{StaticResource PillCornerRadius}"
                        Padding="6,2"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Connected"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
