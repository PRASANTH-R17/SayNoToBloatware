<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SNB.Desktop.Converters"
             xmlns:models="clr-namespace:SNB.Desktop.Models"
             xmlns:vm="clr-namespace:SNB.Desktop.ViewModels"
             x:Class="SNB.Desktop.Dialogs.RemovalConfirmationDialog"
             x:DataType="vm:RemovalConfirmationViewModel"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Border Width="480"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource OutlineVariantBrush}"
            BorderThickness="1"
            CornerRadius="16"
            BoxShadow="0 16 48 0 #18000000"
            Margin="24">
        <Grid RowDefinitions="Auto,*,Auto">

            <Grid Grid.Row="0" Margin="12,12,12,0" ColumnDefinitions="*,Auto">
                <Panel Grid.Column="1" />
                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        Padding="0"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        Command="{Binding CancelCommand}">
                    <PathIcon Width="18"
                              Height="18"
                              Foreground="{StaticResource OnSurfaceVariantBrush}"
                              Data="{StaticResource IconClose}" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          MaxHeight="520"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,8,32,20"
                            Spacing="18"
                            HorizontalAlignment="Stretch">

                    <StackPanel Spacing="14"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding IsAppListExpanded, Converter={x:Static BoolConverters.Not}}">
                        <PathIcon Width="48"
                                  Height="48"
                                  Foreground="{StaticResource WarningBrush}"
                                  Data="{StaticResource IconWarning}"
                                  HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ConfirmationTitle}"
                                   FontFamily="{StaticResource HeaderFontFamily}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OnSurfaceBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="The selected applications will be removed for the current user. This action cannot be undone."
                                   FontSize="14"
                                   Foreground="{StaticResource OnSurfaceVariantBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="21"
                                   MaxWidth="380" />
                    </StackPanel>

                    <Border Background="{StaticResource WarningSoftBrush}"
                            BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <PathIcon Grid.Column="0"
                                      Width="20"
                                      Height="20"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource WarningBrush}"
                                      Data="{StaticResource IconWarning}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{StaticResource OnSurfaceBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="This will free approximately " />
                                <Run Text="{Binding StorageFreedText}"
                                     FontWeight="Bold"
                                     Foreground="{StaticResource WarningBrush}" />
                                <Run Text=" of storage." />
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border BorderBrush="{StaticResource OutlineVariantBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="0">

                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="14,12"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding ToggleAppListCommand}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ToggleLabel}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource OnSurfaceBrush}"
                                               VerticalAlignment="Center" />
                                    <Panel Grid.Column="1" Width="20" Height="20">
                                        <PathIcon IsVisible="{Binding IsAppListExpanded, Converter={x:Static BoolConverters.Not}}"
                                                  Width="20"
                                                  Height="20"
                                                  Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                  Data="{StaticResource IconChevronDown}" />
                                        <PathIcon IsVisible="{Binding IsAppListExpanded}"
                                                  Width="20"
                                                  Height="20"
                                                  Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                  Data="{StaticResource IconChevronUp}" />
                                    </Panel>
                                </Grid>
                            </Button>

                            <StackPanel IsVisible="{Binding IsAppListExpanded}"
                                        Spacing="0">
                                <Border BorderBrush="{StaticResource OutlineVariantBrush}"
                                        BorderThickness="0,1,0,0" />

                                <ScrollViewer MaxHeight="220"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PreviewApps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:ApplicationItemModel">
                                                <Border BorderBrush="{StaticResource OutlineVariantBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="14,10">
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="12">
                                                        <Border Grid.Column="0"
                                                                Width="36"
                                                                Height="36"
                                                                CornerRadius="8"
                                                                ClipToBounds="True"
                                                                VerticalAlignment="Center">
                                                            <Panel>
                                                                <Image Width="36"
                                                                       Height="36"
                                                                       Stretch="UniformToFill"
                                                                       Source="{Binding Source='avares://SNB.Desktop/Assets/app-icon-fallback.png', Converter={x:Static conv:BitmapAssetValueConverter.Instance}}" />
                                                                <Image Width="36"
                                                                       Height="36"
                                                                       Stretch="UniformToFill"
                                                                       Source="{Binding IconPath, Converter={x:Static conv:BitmapAssetValueConverter.Instance}}" />
                                                            </Panel>
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="2"
                                                                    VerticalAlignment="Center"
                                                                    MinWidth="0">
                                                            <TextBlock Text="{Binding AppName}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource OnSurfaceBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding PackageName}"
                                                                       Classes="Code"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Padding="14,10"
                                        BorderBrush="{StaticResource OutlineVariantBrush}"
                                        BorderThickness="0,1,0,0"
                                        IsVisible="{Binding HasMoreApps}">
                                    <TextBlock Text="{Binding MoreAppsText}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource PrimaryBrush}" />
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource OutlineVariantBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="32,16">
                <StackPanel Orientation="Horizontal"
                            Spacing="12"
                            HorizontalAlignment="Center">
                    <Button Classes="Secondary"
                            MinWidth="120"
                            MinHeight="40"
                            Content="Cancel"
                            Command="{Binding CancelCommand}" />
                    <Button Classes="Danger"
                            MinWidth="120"
                            MinHeight="40"
                            Content="Remove"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>

</UserControl>
