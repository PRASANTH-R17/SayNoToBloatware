<Project>
  <!--
    Portable, click-and-run Windows build.
    Produces a self-contained folder containing SNB.Desktop.exe alongside the
    loose runtime assets it depends on at runtime (adb.exe + DLLs, the bridge
    APK, the seed database, and device images). Single-file publishing is
    intentionally NOT used here: it omits these loose <Content> assets from the
    output, which left the installed app unable to find adb.exe / the bridge
    APK. Zip the output folder for distribution; users extract and double-click
    SNB.Desktop.exe.
  -->
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishDir>$(MSBuildProjectDirectory)\..\..\publish\desktop\win-portable\</PublishDir>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
