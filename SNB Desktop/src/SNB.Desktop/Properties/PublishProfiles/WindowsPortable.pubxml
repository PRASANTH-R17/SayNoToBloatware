<Project>
  <!--
    Portable, click-and-run Windows build.
    Produces a single self-contained SNB.Desktop.exe alongside the loose
    runtime assets that must stay as real files (adb.exe + DLLs, the bridge
    APK, the seed database, and device images). Zip the output folder for
    distribution; users extract and double-click SNB.Desktop.exe.
  -->
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishDir>$(MSBuildProjectDirectory)\..\..\publish\desktop\win-portable\</PublishDir>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
