<Project>
  <!--
    Single-file, self-contained Windows build.
    Bundled runtime assets (adb, bridge APK, database, images) are embedded in
    the exe and extracted on first run via IncludeAllContentForSelfExtract.
    AppContext.BaseDirectory points at the extraction directory at startup.
  -->
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishDir>$(MSBuildProjectDirectory)\..\..\publish\desktop\win-single\</PublishDir>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
