<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        SNB Desktop color palette.
        Raw Color tokens live in per-variant ThemeDictionaries (Light / Dark) so the whole
        app re-themes when Application.RequestedThemeVariant changes. The Brush resources are
        defined once and reference the colors via DynamicResource so they pick up the active
        variant automatically. Light values match the design.md Material 3 token set; Dark
        values are a Fluent-style neutral dark-gray palette.
        Naming: {Role}Color (raw Color) + {Role}Brush (SolidColorBrush).
    -->

    <ResourceDictionary.ThemeDictionaries>

        <!-- ============================ LIGHT ============================ -->
        <ResourceDictionary x:Key="{x:Static ThemeVariant.Light}">

            <!-- Surfaces -->
            <Color x:Key="SurfaceTintColor">#FAF8FF</Color>
            <Color x:Key="SurfaceDimColor">#D2D9F4</Color>
            <Color x:Key="SurfaceContainerLowestColor">#FFFFFF</Color>
            <Color x:Key="SurfaceContainerLowColor">#F2F3FF</Color>
            <Color x:Key="SurfaceContainerColor">#EAEDFF</Color>
            <Color x:Key="SurfaceContainerHighColor">#E2E7FF</Color>
            <Color x:Key="SurfaceContainerHighestColor">#DAE2FD</Color>

            <!-- On-surface / outlines -->
            <Color x:Key="OnSurfaceColor">#131B2E</Color>
            <Color x:Key="OnSurfaceVariantColor">#434655</Color>
            <Color x:Key="OutlineColor">#737686</Color>
            <Color x:Key="OutlineVariantColor">#C3C6D7</Color>

            <!-- Primary -->
            <Color x:Key="PrimaryColor">#004AC6</Color>
            <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
            <Color x:Key="PrimaryContainerColor">#2563EB</Color>
            <Color x:Key="OnPrimaryContainerColor">#FFFFFF</Color>

            <!-- Secondary -->
            <Color x:Key="SecondaryColor">#505F76</Color>
            <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
            <Color x:Key="SecondaryContainerColor">#D3E4FE</Color>
            <Color x:Key="OnSecondaryContainerColor">#0B1C30</Color>

            <!-- Error -->
            <Color x:Key="ErrorColor">#BA1A1A</Color>
            <Color x:Key="OnErrorColor">#FFFFFF</Color>
            <Color x:Key="ErrorContainerColor">#FFDAD6</Color>
            <Color x:Key="OnErrorContainerColor">#410002</Color>

            <!-- Brand / accent (blue) maps to primary -->
            <Color x:Key="AccentColor">#004AC6</Color>
            <Color x:Key="AccentHoverColor">#0A57DA</Color>
            <Color x:Key="AccentPressedColor">#003693</Color>
            <Color x:Key="AccentSoftColor">#DBE1FF</Color>

            <!-- Semantic -->
            <Color x:Key="SuccessColor">#16A34A</Color>
            <Color x:Key="SuccessSoftColor">#E7F6EC</Color>
            <Color x:Key="WarningColor">#D97706</Color>
            <Color x:Key="WarningSoftColor">#FEF3E2</Color>
            <Color x:Key="DangerColor">#BA1A1A</Color>
            <Color x:Key="DangerHoverColor">#93000A</Color>
            <Color x:Key="DangerSoftColor">#FFDAD6</Color>

            <!-- Neutral grays mapped to design on-surface / outline tokens -->
            <Color x:Key="TextPrimaryColor">#131B2E</Color>
            <Color x:Key="TextSecondaryColor">#434655</Color>
            <Color x:Key="TextMutedColor">#737686</Color>
            <Color x:Key="BorderColor">#C3C6D7</Color>
            <Color x:Key="DividerColor">#DAE2FD</Color>
            <Color x:Key="SubtleOutlineColor">#E9ECF4</Color>
            <Color x:Key="SubtleDividerColor">#F0F2F8</Color>
            <Color x:Key="InfoColor">#7C3AED</Color>

            <!-- Surfaces / backgrounds -->
            <Color x:Key="BackgroundColor">#FAF8FF</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceAltColor">#F2F3FF</Color>
            <Color x:Key="SidebarColor">#F2F3FF</Color>
            <Color x:Key="OverlayScrimColor">#66000000</Color>

        </ResourceDictionary>

        <!-- ============================ DARK ============================ -->
        <ResourceDictionary x:Key="{x:Static ThemeVariant.Dark}">

            <!-- Surfaces -->
            <Color x:Key="SurfaceTintColor">#1B1B1F</Color>
            <Color x:Key="SurfaceDimColor">#121214</Color>
            <Color x:Key="SurfaceContainerLowestColor">#141417</Color>
            <Color x:Key="SurfaceContainerLowColor">#1E1E22</Color>
            <Color x:Key="SurfaceContainerColor">#232328</Color>
            <Color x:Key="SurfaceContainerHighColor">#2A2A30</Color>
            <Color x:Key="SurfaceContainerHighestColor">#34343A</Color>

            <!-- On-surface / outlines -->
            <Color x:Key="OnSurfaceColor">#E4E2E6</Color>
            <Color x:Key="OnSurfaceVariantColor">#C5C6D0</Color>
            <Color x:Key="OutlineColor">#8D909B</Color>
            <Color x:Key="OutlineVariantColor">#43474E</Color>

            <!-- Primary (lightened so it reads on dark surfaces) -->
            <Color x:Key="PrimaryColor">#6FA8FF</Color>
            <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
            <Color x:Key="PrimaryContainerColor">#2563EB</Color>
            <Color x:Key="OnPrimaryContainerColor">#FFFFFF</Color>

            <!-- Secondary -->
            <Color x:Key="SecondaryColor">#9AA8C2</Color>
            <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
            <Color x:Key="SecondaryContainerColor">#2A3442</Color>
            <Color x:Key="OnSecondaryContainerColor">#D3E4FE</Color>

            <!-- Error -->
            <Color x:Key="ErrorColor">#FF6B6B</Color>
            <Color x:Key="OnErrorColor">#FFFFFF</Color>
            <Color x:Key="ErrorContainerColor">#93000A</Color>
            <Color x:Key="OnErrorContainerColor">#FFDAD6</Color>

            <!-- Brand / accent (mid blue keeps white button text legible) -->
            <Color x:Key="AccentColor">#3B82F6</Color>
            <Color x:Key="AccentHoverColor">#5A95F7</Color>
            <Color x:Key="AccentPressedColor">#2563EB</Color>
            <Color x:Key="AccentSoftColor">#25324D</Color>

            <!-- Semantic (brightened for dark) -->
            <Color x:Key="SuccessColor">#4ADE80</Color>
            <Color x:Key="SuccessSoftColor">#16301F</Color>
            <Color x:Key="WarningColor">#FBBF24</Color>
            <Color x:Key="WarningSoftColor">#332408</Color>
            <Color x:Key="DangerColor">#FF6B6B</Color>
            <Color x:Key="DangerHoverColor">#FF8A8A</Color>
            <Color x:Key="DangerSoftColor">#3B1A1A</Color>

            <!-- Neutral grays -->
            <Color x:Key="TextPrimaryColor">#E4E2E6</Color>
            <Color x:Key="TextSecondaryColor">#C5C6D0</Color>
            <Color x:Key="TextMutedColor">#8E9099</Color>
            <Color x:Key="BorderColor">#43474E</Color>
            <Color x:Key="DividerColor">#34343A</Color>
            <Color x:Key="SubtleOutlineColor">#2A2A30</Color>
            <Color x:Key="SubtleDividerColor">#232328</Color>
            <Color x:Key="InfoColor">#A78BFA</Color>

            <!-- Surfaces / backgrounds -->
            <Color x:Key="BackgroundColor">#1B1B1F</Color>
            <Color x:Key="SurfaceColor">#2A2A30</Color>
            <Color x:Key="SurfaceAltColor">#232328</Color>
            <Color x:Key="SidebarColor">#202024</Color>
            <Color x:Key="OverlayScrimColor">#99000000</Color>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Brush resources (variant-aware via DynamicResource) ===== -->

    <!-- Design-token brushes -->
    <SolidColorBrush x:Key="SurfaceTintBrush" Color="{DynamicResource SurfaceTintColor}" />
    <SolidColorBrush x:Key="SurfaceDimBrush" Color="{DynamicResource SurfaceDimColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="{DynamicResource SurfaceContainerLowestColor}" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="{DynamicResource SurfaceContainerLowColor}" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{DynamicResource SurfaceContainerColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="{DynamicResource SurfaceContainerHighColor}" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="{DynamicResource SurfaceContainerHighestColor}" />

    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{DynamicResource OnSurfaceColor}" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{DynamicResource OnSurfaceVariantColor}" />
    <SolidColorBrush x:Key="OutlineBrush" Color="{DynamicResource OutlineColor}" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{DynamicResource OutlineVariantColor}" />
    <SolidColorBrush x:Key="SubtleOutlineBrush" Color="{DynamicResource SubtleOutlineColor}" />
    <SolidColorBrush x:Key="SubtleDividerBrush" Color="{DynamicResource SubtleDividerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="{DynamicResource InfoColor}" Opacity="0.10" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{DynamicResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{DynamicResource PrimaryContainerColor}" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{DynamicResource OnPrimaryContainerColor}" />
    <!-- primary/10 and primary/20 used by active filter chips -->
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.08" />
    <SolidColorBrush x:Key="PrimaryOutlineBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.18" />
    <SolidColorBrush x:Key="PrimaryMutedBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.04" />
    <SolidColorBrush x:Key="PrimaryContainerSoftBrush" Color="{DynamicResource PrimaryContainerColor}" Opacity="0.12" />
    <SolidColorBrush x:Key="SuccessOutlineBrush" Color="{DynamicResource SuccessColor}" Opacity="0.16" />

    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="{DynamicResource OnSecondaryColor}" />
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="{DynamicResource SecondaryContainerColor}" />
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="{DynamicResource OnSecondaryContainerColor}" />

    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}" />
    <SolidColorBrush x:Key="OnErrorBrush" Color="{DynamicResource OnErrorColor}" />
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="{DynamicResource ErrorContainerColor}" />
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="{DynamicResource OnErrorContainerColor}" />

    <!-- Existing aliases -->
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{DynamicResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{DynamicResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{DynamicResource WarningSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{DynamicResource DangerHoverColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{DynamicResource DangerSoftColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{DynamicResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{DynamicResource SidebarColor}" />
    <SolidColorBrush x:Key="OverlayScrimBrush" Color="{DynamicResource OverlayScrimColor}" />

    <!-- Shared metrics (design.md radii) -->
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="CardCornerRadiusXl">20</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadiusLg">14</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">999</CornerRadius>

    <!-- Prefer requested design fonts when available, with sensible OS fallbacks. -->
    <FontFamily x:Key="HeaderFontFamily">Hanken Grotesk, Inter, Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="BodyFontFamily">Inter, Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="AppFontFamily">Inter, Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFontFamily">JetBrains Mono, Cascadia Code, Cascadia Mono, Consolas, Menlo, monospace</FontFamily>

</ResourceDictionary>
